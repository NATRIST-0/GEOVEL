  <property name="styleSheet">
   <string notr="true">/* ============================================================
   GLOBAL
   ============================================================ */
QWidget {
    background-color: #FAFAFA;
    color: #333333;
	font-family: 'Segoe UI';
}

QMainWindow {
    background-color: #FAFAFA;
    color: #333333;
}


/* ============================================================
   BOUTONS
   ============================================================ */
QPushButton {
    background-color: #F5F5F5;
    border: 1px solid #D0D0D0;
    border-radius: 0px;
    padding: 4px 8px;
	font-family: 'Segoe UI';
    font-weight: normal;
    color: #333333;
}

QPushButton:hover    { background-color: #C96868; border-color: #B55555; color: #FFFFFF; }
QPushButton:pressed  { background-color: #7EACB5; border-color: #5E9CA5; color: #FFFFFF; }
QPushButton:disabled { background-color: #F8F8F8; border-color: #E0E0E0; color: #999999; }


/* ============================================================
   CHAMPS DE SAISIE
   ============================================================ */
QLineEdit,
QTextEdit,
QSpinBox,
QDoubleSpinBox,
QDateTimeEdit,
QDateEdit,
QTimeEdit {
    background-color: #FFFFFF;
    color: #333333;
    border: 1px solid #E0E0E0;
    border-radius: 0px;
    padding: 4px;    
	font-family: 'Segoe UI';
    selection-background-color: #E0E0E0;
    selection-color: #333333;
}

QLineEdit:focus,
QTextEdit:focus,
QSpinBox:focus,
QDoubleSpinBox:focus,
QDateTimeEdit:focus,
QDateEdit:focus,
QTimeEdit:focus {
    border-color: #C0C0C0;
}

/* Boutons up/down des SpinBox et DateTimeEdit */
QSpinBox::up-button,
QSpinBox::down-button,
QDoubleSpinBox::up-button,
QDoubleSpinBox::down-button,
QDateTimeEdit::up-button,
QDateTimeEdit::down-button,
QDateEdit::up-button,
QDateEdit::down-button,
QTimeEdit::up-button,
QTimeEdit::down-button {
    background-color: #F5F5F5;
    border: none;
    border-left: 1px solid #E0E0E0;
    border-radius: 0px;
    width: 16px;
}

QSpinBox::up-button:hover,
QSpinBox::down-button:hover,
QDoubleSpinBox::up-button:hover,
QDoubleSpinBox::down-button:hover,
QDateTimeEdit::up-button:hover,
QDateTimeEdit::down-button:hover,
QDateEdit::up-button:hover,
QDateEdit::down-button:hover,
QTimeEdit::up-button:hover,
QTimeEdit::down-button:hover {
    background-color: #C96868;
}


/* ============================================================
   GROUPBOX
   ============================================================ */
QGroupBox {
    background-color: #FAFAFA;
    border: 1px solid #D0D0D0;
    border-radius: 0px;
    margin-top: 8px;
    padding-top: 8px;
	font-family: 'Segoe UI';
    color: #333333;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 4px;
    color: #333333;
}


/* ============================================================
   MENU BAR &amp; MENUS
   ============================================================ */
QMenuBar {
    background-color: #F5F5F5;
    border: 1px solid #D0D0D0;
    border-radius: 0px;
	font-family: 'Segoe UI';
    font-weight: normal;
    color: #333333;
}

QMenuBar::item             	{ background-color: transparent; color: #333333; padding: 4px 8px; }
QMenuBar::item:selected    { background-color: #C96868; color: #FFFFFF; }
QMenuBar::item:pressed     { background-color: #7EACB5; color: #FFFFFF; }

QMenu {
    background-color: #FFFFFF;
    color: #333333;
    border: 1px solid #D0D0D0;
    border-radius: 0px;
}

QMenu::item              { padding: 4px 20px; }
QMenu::item:selected     { background-color: #C96868; color: #FFFFFF; }
QMenu::item:pressed      { background-color: #7EACB5; color: #FFFFFF; }


/* ============================================================
   SCROLLBARS
   ============================================================ */
QScrollBar:vertical {
    background-color: #F5F5F5;
    width: 12px;
    margin: 1px;
    border-radius: 0px;
}

QScrollBar::handle:vertical {
    background-color: #E0E0E0;
    border: 1px solid #D0D0D0;
    border-radius: 0px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover { background-color: #D0D0D0; }

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background-color: #F5F5F5;
    height: 12px;
    margin: 1px;
    border-radius: 0px;
}

QScrollBar::handle:horizontal {
    background-color: #E0E0E0;
    border: 1px solid #D0D0D0;
    border-radius: 0px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover { background-color: #D0D0D0; }

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}</string>
